#include "timer_configure.h"
#include <avr/interrupt.h>

#define DDRB_REG  (*(volatile uint8_t *)0x24)
#define PORTB_REG (*(volatile uint8_t *)0x25)

volatile uint16_t compare_count = 0;

void setup()
{
    DDRB_REG = 0xFF;

    timer0_setmode(TIMER0_CTC_MODE);
    timer0_setcounter(0);
    timer0_setcompareA(249);

    timer0_compareA_interrupt_enable();
    timer0_start(TIMER_PRESCALER_64);

    global_interrupt_enable();
}

void loop()
{
}

ISR(TIMER0_COMPA_vect)
{
    compare_count++;

    if(compare_count >= 1000)
    {
        compare_count = 0;
        PORTB_REG ^= 0xFF;
    }
}