#include "timer_configure.h"

#define DDRB_REG  (*(volatile uint8_t *)0x24)
#define PORTB_REG (*(volatile uint8_t *)0x25)

void setup()
{
    DDRB_REG = 0xFF;
}

void loop()
{
    PORTB_REG = 0xFF;

    timer0_setmode(TIMER0_NORMAL_MODE);
    timer0_setcounter(6);
    timer0_clear_overflow_flag();
    timer0_start(TIMER_PRESCALER_64);

    while((TIFR0 & (1 << 0)) == 0);

    timer0_clear_overflow_flag();
    timer0_stop();

    PORTB_REG = 0x00;

    timer0_setmode(TIMER0_NORMAL_MODE);
    timer0_setcounter(6);
    timer0_clear_overflow_flag();
    timer0_start(TIMER_PRESCALER_64);

    while((TIFR0 & (1 << 0)) == 0);

    timer0_clear_overflow_flag();
    timer0_stop();
}